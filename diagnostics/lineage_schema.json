{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Probability Lineage Trace",
  "type": "object",
  "required": ["pick_id", "inputs", "steps", "final"],
  "properties": {
    "pick_id": {"type": "string"},
    "inputs": {"type": "object"},
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "params", "output"],
        "properties": {
          "stage": {"type": "string"},
          "params": {"type": "object"},
          "output": {"type": "object"}
        }
      }
    },
    "final": {"type": "object"}
  }
}
